generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

// ENUMS

enum Role {
  SUPER_ADMIN
  NGO_ADMIN
  MODERATOR
  USER
}

enum ReportType {
  HARASSMENT
  DOMESTIC_VIOLENCE
  STALKING
  CORRUPTION
  THREAT
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  VERIFIED
  REJECTED
}

enum CaseStatus {
  UNDER_REVIEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

// USER 

model User {
  id            String   @id @default(uuid())
  name          String?
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  role          Role     @default(USER)
  ngoId         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  reports             Report[]
  notifications       Notification[]
  donations           Donation[]
  reportVerifications ReportVerification[]
  caseNotes           CaseNote[]
  sessions            Session[]
  accounts            Account[]

  ngo NGO? @relation(fields: [ngoId], references: [id])
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
  @@index([identifier])
}

// NGO

model NGO {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String
  address   String
  createdAt DateTime @default(now())

  users User[]
  cases Case[]
}

// REPORT

model Report {
  id          String       @id @default(uuid())
  userId      String
  type        ReportType
  description String
  location    String
  status      ReportStatus @default(SUBMITTED)
  isAnonymous Boolean      @default(false)
  createdAt   DateTime     @default(now())

  // Relations
  user         User                @relation(fields: [userId], references: [id])
  evidence     Evidence[]
  case         Case?
  verification ReportVerification?

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

// EVIDENCE

model Evidence {
  id        String   @id @default(uuid())
  reportId  String
  fileUrl   String
  fileType  String
  createdAt DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id])

  @@index([reportId])
}

// CASE

model Case {
  id            String     @id @default(uuid())
  reportId      String     @unique
  assignedNgoId String
  status        CaseStatus @default(UNDER_REVIEW)
  priority      String
  createdAt     DateTime   @default(now())

  report Report     @relation(fields: [reportId], references: [id])
  ngo    NGO        @relation(fields: [assignedNgoId], references: [id])
  notes  CaseNote[]

  @@index([assignedNgoId])
}

model CaseNote {
  id        String   @id @default(uuid())
  caseId    String
  authorId  String
  note      String
  createdAt DateTime @default(now())

  case   Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([authorId])
  @@index([createdAt])
}

// VERIFICATION

model ReportVerification {
  id          String             @id @default(uuid())
  reportId    String             @unique
  moderatorId String
  status      VerificationStatus @default(PENDING)
  feedback    String?
  createdAt   DateTime           @default(now())

  report    Report @relation(fields: [reportId], references: [id])
  moderator User   @relation(fields: [moderatorId], references: [id])

  @@index([moderatorId])
}

// NOTIFICATION

model Notification {
  id        String   @id @default(uuid())
  userId    String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// DONATION

model Donation {
  id            String        @id @default(uuid())
  userId        String
  amount        Float
  paymentStatus PaymentStatus @default(PENDING)
  transactionId String
  createdAt     DateTime      @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}
